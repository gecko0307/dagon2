{
    "name": "dagon2",
    "description": "3D game engine for D",
    "homepage": "https://gecko0307.github.io/dagon",
    "license": "BSL-1.0",
    "authors": [
        "Timur Gafarov",
        "Rafał Ziemniewski",
        "Björn Roberg",
        "Viktor M.",
        "Mateusz Muszyński",
        "Denis Feklushkin",
        "Konstantin Menshikov",
        "Vlad Davydov",
        "Joshua T. Fisher",
        "Vadim Lopatin"
    ],
    
    "importPaths": [
        "src"
    ],
    
     "sourcePaths": [
        "src"
    ],
    
    "stringImportPaths": ["data/__internal"],
    
    "dependencies": {
        "dlib": "~>1.4.1",
        "bindbc-glslang": "~>0.1.0",
        "bindbc-sdl": "~>2.3.4",
        "bindbc-spirvcross": "~>0.1.1",
        "bindbc-freetype": "1.3.2"
    },

    "versions": [
        "SDL_3_4_0",
        "SDL_Image_3_2",
        "FT_28"
    ],

    "buildRequirements":[
        "allowWarnings"
    ],

    "libs-windows": ["user32", "comdlg32", "Dbghelp"],

    "configurations": [
        {
            "name": "library",
            "targetType": "library"
        }
    ],

    "copyFiles": ["license", "data", "gamecontrollerdb.txt"],
    "copyFiles-linux-x86_64": ["lib/linux-x64/*"],
    "copyFiles-windows-x86_64": ["lib/windows-x64/*"],

    "-ddoxTool": "scod"
}
