module dagon.resource.shader.glsl;

import std.stdio;
import std.conv;
import dagon.core.glslang;
import dagon.resource.shader.shadermodule;

struct ShaderCompilationResult
{
    uint[] spirv;
    bool success;
}

ShaderCompilationResult compileGLSLtoSPIRV(string src, PipelineStage pipelineStage)
{
    ShaderCompilationResult res;
    res.success = false;
    
    glslang_stage_t stage;
    if (pipelineStage == PipelineStage.Vertex)
        stage = GLSLANG_STAGE_VERTEX;
    else if (pipelineStage == PipelineStage.Fragment)
        stage = GLSLANG_STAGE_FRAGMENT;
    
    glslang_input_t input = {
        language: GLSLANG_SOURCE_GLSL,
        stage: stage,
        client: GLSLANG_CLIENT_VULKAN,
        client_version: GLSLANG_TARGET_VULKAN_1_3,
        target_language: GLSLANG_TARGET_SPV,
        target_language_version: GLSLANG_TARGET_SPV_1_5,
        code: src.ptr,
        default_version: 450,
        default_profile: GLSLANG_NO_PROFILE,
        force_default_version_and_profile: false,
        forward_compatible: false,
        messages:
            GLSLANG_MSG_DEFAULT_BIT | GLSLANG_MSG_DEBUG_INFO_BIT |
            GLSLANG_MSG_ENHANCED    | GLSLANG_MSG_CASCADING_ERRORS_BIT |
            GLSLANG_MSG_DEBUG_INFO_BIT,
        resource: &glslangDefaultResource,
        callbacks: {
            include_local: null,
            include_system: null,
            free_include_result: null
        },
        callbacks_ctx: null
    };
    
    glslang_shader_t* shader = glslang_shader_create(&input);
    
    bool failed = false;
    if (glslang_shader_preprocess(shader, &input) == 0)
        failed = true;
    else if (glslang_shader_parse(shader, &input) == 0)
        failed = true;
    
    if (failed)
    {
        const infoLog = glslang_shader_get_info_log(shader);
        writeln(infoLog.to!string);
        return res;
    }
    
    glslang_program_t* program = glslang_program_create();
    
    glslang_program_add_shader(program, shader);
    
    failed = false;
    if (glslang_program_link(program, GLSLANG_MSG_SPV_RULES_BIT | GLSLANG_MSG_VULKAN_RULES_BIT) == 0)
        failed = true;
    else if (glslang_program_map_io(program) == 0)
        failed = true;
    
    if (failed)
    {
        const infoLog = glslang_shader_get_info_log(shader);
        writeln(infoLog.to!string);
        return res;
    }
    
    glslang_program_add_source_text(program, stage, src.ptr, src.length);
    
    glslang_program_SPIRV_generate(program, stage);
    
    auto spirvMessages = glslang_program_SPIRV_get_messages(program);
    if (spirvMessages !is null)
    {
        writeln(spirvMessages.to!string);
        return res;
    }
    
    auto spirSize = glslang_program_SPIRV_get_size(program);
    auto spirPtr = glslang_program_SPIRV_get_ptr(program);
    res.spirv = spirPtr[0..spirSize];
    res.success = true;
    return res;
}

